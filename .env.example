# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- API server ---
PORT=4000
# Set a strong random value in production (falls back to a dev-only default otherwise).
JWT_SECRET=change-me-to-a-long-random-string
# Public base URL of the API / app (used for links + CORS). Optional in dev.
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# --- Video capture (GIF/MP4 export) ---
# URL of the running SPA the capture service loads (Vite dev server, or the deployed site).
# Requires ffmpeg + a Playwright chromium install on the host.
CAPTURE_BASE_URL=http://localhost:5173

# --- Image storage (card images + rendered GIF/MP4 exports) ---
# Leave S3_* unset to store on local disk under server/uploads (served at /uploads).
# Set S3_BUCKET (+ AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) to use object storage.
#
# Cloudflare R2 (recommended — 10GB free, zero egress fees):
#   S3_BUCKET=r5c
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   AWS_REGION=auto
#   S3_PUBLIC_BASE=https://<your-r2-public-domain>   # r2.dev URL or a custom domain
#   AWS_ACCESS_KEY_ID=<r2 access key id>
#   AWS_SECRET_ACCESS_KEY=<r2 secret access key>
#
# Plain AWS S3 instead: set S3_BUCKET + AWS_REGION (+ credentials); leave S3_ENDPOINT unset.
# Note: card images live under the card-images/ prefix (permanent); exports live under
# renders/ — set a bucket lifecycle rule to expire renders/ after ~14 days.
# S3_BUCKET=
# S3_ENDPOINT=
# AWS_REGION=auto
# S3_PUBLIC_BASE=
# Override the local uploads directory if needed.
# R5C_UPLOADS_DIR=

# --- Database ---
# Leave DATABASE_URL unset to run on the JSON file store (server/data/db.json) —
# no database needed for local dev. Set it to a Postgres connection string to use
# Postgres as the system of record: the schema is applied automatically on startup
# (server/config/schema.sql), and the working set write-throughs to it.
# DATABASE_URL=postgresql://user:password@localhost:5432/r5c

# --- Frontend (build-time, Vite) ---
# Base URL the SPA calls. Defaults to http://localhost:4000 if unset.
VITE_API_URL=http://localhost:4000
